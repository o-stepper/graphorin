{
  "name": "@graphorin/example-slack-bot-integration",
  "version": "0.13.11",
  "private": true,
  "description": "Slack bot integration demo for the Graphorin framework. Server-mode example that converts Slack webhook events into agent runs, streams replies back over WebSocket, and demonstrates durable HITL approvals across server restarts plus token-based HMAC + pepper auth. Created and maintained by Oleksiy Stepurenko.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/examples/slack-bot-integration",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "examples/slack-bot-integration"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "example",
    "oleksiy-stepurenko"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx ./src/main.ts",
    "build": "tsdown",
    "start": "node ./dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/agent": "workspace:*",
    "@graphorin/client": "workspace:*",
    "@graphorin/memory": "workspace:*",
    "@graphorin/protocol": "workspace:*",
    "@graphorin/security": "workspace:*",
    "@graphorin/server": "workspace:*",
    "@graphorin/sessions": "workspace:*",
    "@graphorin/store-sqlite": "workspace:*",
    "@graphorin/embedder-transformersjs": "workspace:*",
    "@graphorin/example-trace-helper": "workspace:*",
    "@graphorin/observability": "workspace:*",
    "@graphorin/provider": "workspace:*",
    "@graphorin/tools": "workspace:*"
  },
  "bin": {
    "graphorin-example-slack-bot-integration": "./dist/main.js"
  }
}
