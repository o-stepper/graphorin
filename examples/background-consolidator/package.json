    "@graphorin/embedder-transformersjs": "workspace:*",
    "@graphorin/example-trace-helper": "workspace:*",
    "@graphorin/observability": "workspace:*",
    "@graphorin/provider": "workspace:*",
    "@graphorin/triggers": "workspace:*",
    "@graphorin/security": "workspace:*"
  },
  "bin": {
    "graphorin-example-background-consolidator": "./dist/main.js"
  }
