{
  "name": "@graphorin/example-three-agent-harness",
  "version": "0.13.3",
  "private": true,
  "description": "Three-agent orchestration harness demo for the Graphorin framework. Demonstrates the Planner / Generator / Evaluator pattern with structured-handoff artifacts (agent.progress.write/read), evaluatorOptimizer({...}) self-revision loop, and an optional Agent.fanOut({...}) research-and-decide variant with createCitationAgent post-processing. Created and maintained by Oleksiy Stepurenko.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/examples/three-agent-harness",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "examples/three-agent-harness"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "example",
    "oleksiy-stepurenko"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx ./src/main.ts",
    "build": "tsdown",
    "start": "node ./dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/agent": "workspace:*",
    "@graphorin/example-trace-helper": "workspace:*",
    "@graphorin/provider": "workspace:*"
  },
  "bin": {
    "graphorin-example-three-agent-harness": "./dist/main.js"
  }
}
