{
  "name": "@graphorin/example-personal-assistant-cli",
  "version": "0.13.2",
  "private": true,
  "description": "Single-agent local CLI personal assistant for the Graphorin framework. Library-mode walkthrough that wires createAgent({...}) to memory + sensitivity tiers + first-run prompt + optional encryption-at-rest, with three opt-in local-LLM recipes (Ollama HTTP, llama.cpp HTTP, in-process llama.cpp). Created and maintained by Oleksiy Stepurenko.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/examples/personal-assistant-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "examples/personal-assistant-cli"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "example",
    "oleksiy-stepurenko"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx ./src/main.ts",
    "build": "tsdown",
    "start": "node ./dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/agent": "workspace:*",
    "@graphorin/memory": "workspace:*",
    "@graphorin/store-sqlite": "workspace:*",
    "@graphorin/embedder-transformersjs": "workspace:*",
    "@graphorin/embedder-ollama": "workspace:*",
    "@graphorin/example-trace-helper": "workspace:*",
    "@graphorin/observability": "workspace:*",
    "@graphorin/provider": "workspace:*",
    "@graphorin/sessions": "workspace:*",
    "@graphorin/tools": "workspace:*"
  },
  "bin": {
    "graphorin-example-personal-assistant-cli": "./dist/main.js"
  }
}
