{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".npmrc", "biome.json", "vitest.workspace.ts"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsconfig.json", "tsdown.config.ts", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": ["*.tsbuildinfo"],
      "inputs": ["src/**", "tests/**", "tsconfig.json", "tsconfig.tests.json", "package.json"]
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "tests/**", "vitest.config.ts", "tsconfig.tests.json", "package.json"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", "tests/**", "biome.json"]
    },
    "clean": {
      "cache": false,
      "outputs": []
    }
  }
}
