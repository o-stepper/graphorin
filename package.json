{
  "name": "graphorin",
  "version": "0.14.0",
  "private": true,
  "description": "Graphorin - TypeScript framework for building long-living personal AI assistants. Created and maintained by Oleksiy Stepurenko. MIT License.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "check-no-network": "node ./scripts/check-no-network.mjs",
    "check-api-wording": "node ./scripts/check-api-wording.mjs",
    "check-doc-snippets": "node ./scripts/check-doc-snippets.mjs",
    "check-cli-docs": "node ./scripts/check-cli-docs.mjs",
    "check-example-docs": "node ./scripts/check-example-docs.mjs",
    "check-version-consistency": "node ./scripts/check-version-consistency.mjs",
    "check-phantom-deps": "node ./scripts/check-phantom-deps.mjs",
    "check-character-rules": "node ./scripts/check-character-rules.mjs",
    "check-doc-links": "node ./scripts/check-doc-links.mjs",
    "check-api-report": "node ./scripts/check-api-report.mjs",
    "check-entry-guards": "node ./scripts/check-entry-guards.mjs",
    "check-benchmark-readmes": "node ./scripts/check-benchmark-readmes.mjs",
    "check-package-shape": "node ./scripts/check-package-shape.mjs",
    "check-gates-selftest": "node ./scripts/check-cli-docs.mjs --self-test && node ./scripts/check-example-docs.mjs --self-test && node ./scripts/check-no-network.mjs --self-test && node ./scripts/check-doc-snippets.mjs --self-test && node ./scripts/check-character-rules.mjs --self-test && node ./scripts/check-doc-links.mjs --self-test && node ./scripts/check-benchmark-readmes.mjs --self-test && node ./documentation/scripts/build-llms-txt.mjs --self-test && node ./documentation/scripts/check-dist-budget.mjs --self-test && node ./documentation/scripts/build-benchmark-results.mjs --self-test && node ./scripts/check-entry-guards.mjs --self-test && node ./scripts/check-api-wording.mjs --self-test",
    "bump-version": "node ./scripts/bump-version.mjs",
    "smoke-examples": "node ./scripts/smoke-examples.mjs",
    "smoke-consumer": "node ./scripts/smoke-consumer.mjs",
    "mvp-readiness": "node ./scripts/mvp-readiness.mjs",
    "docs:dev": "pnpm --filter @graphorin/docs dev",
    "docs:build": "pnpm --filter @graphorin/docs build:site",
    "docs:preview": "pnpm --filter @graphorin/docs preview",
    "docs:clean": "pnpm --filter @graphorin/docs clean",
    "benchmark:ci": "pnpm run check-example-docs && pnpm run build && pnpm --filter @graphorin/benchmark-memory-smoke run benchmark:run && pnpm --filter @graphorin/benchmark-cost run benchmark:run && pnpm --filter @graphorin/benchmark-latency run benchmark:smoke && pnpm --filter @graphorin/benchmark-memory-sim run benchmark:smoke && pnpm --filter @graphorin/benchmark-scale run benchmark:smoke && pnpm --filter @graphorin/benchmark-dialogue-smoke run benchmark:run && pnpm --filter @graphorin/benchmark-tool-agent run benchmark:run && pnpm --filter @graphorin/benchmark-halumem run benchmark:smoke && pnpm --filter @graphorin/benchmark-conformance run benchmark:run",
    "benchmark:longmemeval": "pnpm --filter @graphorin/benchmark-longmemeval run build && node ./benchmarks/longmemeval/dist/runner.js",
    "check-licenses": "node ./scripts/check-licenses.mjs",
    "check-anthropic-spec": "node ./scripts/check-anthropic-spec.mjs",
    "changeset": "changeset",
    "version": "changeset version && node scripts/bump-version.mjs --sync && node documentation/scripts/sync-root-docs.mjs && pnpm install --lockfile-only --no-frozen-lockfile",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@biomejs/biome": "^2.0.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.10",
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "0.3.21",
    "rimraf": "^6.0.1",
    "tsdown": "^0.16.0",
    "tsx": "^4.20.0",
    "turbo": "^2.9.14",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "better-sqlite3-multiple-ciphers",
      "esbuild",
      "sqlite-vec"
    ],
    "overrides": {
      "esbuild@<0.28.1": ">=0.28.1 <0.29",
      "vite@>=5.0.0 <6.0.0": "^7.3.5",
      "vite@>=7.0.0 <7.3.5": "^7.3.5",
      "protobufjs@<7.6.5": ">=7.6.5 <8",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0 <9",
      "protobufjs@>=8.0.0 <8.6.0": ">=8.6.0 <9",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2 <7",
      "dockerode>uuid": ">=11.1.1 <12",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": ">=1.14.4 <2",
      "hono@<4.12.25": ">=4.12.25 <5",
      "@hono/node-server@<2.0.5": ">=2.0.5 <3",
      "@opentelemetry/core@>=2.0.0 <2.8.0": ">=2.8.0 <3",
      "dompurify@<3.4.12": ">=3.4.12 <4",
      "fast-uri@>=3.0.0 <3.1.4": ">=3.1.4 <4",
      "sharp@>=0.30.0 <0.35.0": ">=0.35.0 <0.36",
      "linkify-it@<5.0.1": ">=5.0.1 <6",
      "markdown-it@<14.2.0": ">=14.2.0 <15",
      "tar@>=7.0.0 <7.5.16": ">=7.5.16 <8",
      "js-yaml@>=4.0.0 <4.2.0": ">=4.2.0 <5",
      "js-yaml@<3.15.0": ">=3.15.0 <4",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6 <6",
      "adm-zip@<0.6.0": ">=0.6.0 <1",
      "body-parser@<2.3.0": ">=2.3.0 <3"
    }
  }
}
