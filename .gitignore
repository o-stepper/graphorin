# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.turbo/
*.tsbuildinfo

# Foreign lockfiles (pnpm is the project default; only pnpm-lock.yaml is committed)
package-lock.json
yarn.lock
bun.lockb

# Test / coverage
coverage/
.vitest-cache/
*.lcov

# Benchmark runners write timestamped reports on each run (see packages' runner.ts)
benchmarks/**/RESULTS.md

# Local data emitted by the framework at runtime
.graphorin/
*.db
*.db-wal
*.db-shm

# Environment / secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.claude/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Misc
.cache/
.tmp/
tmp/
