{
  "name": "@graphorin/benchmark-memory-sim",
  "version": "0.8.0",
  "private": true,
  "description": "Lightweight synthetic dialogue-simulator benchmark for the Graphorin framework. Generates deterministic conversational fixtures with seeded PRNGs, then scores memory recall on a retrieval task and reports simulation accuracy. Created and maintained by Oleksiy Stepurenko.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/benchmarks/memory-sim",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "benchmarks/memory-sim"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "benchmark",
    "memory-evaluation"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx ./src/runner.ts",
    "build": "tsdown",
    "start": "node ./dist/runner.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "benchmark:run": "node ./dist/runner.js",
    "benchmark:smoke": "node ./dist/runner.js --smoke"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/memory": "workspace:*",
    "@graphorin/store-sqlite": "workspace:*"
  },
  "bin": {
    "graphorin-benchmark-memory-sim": "./dist/runner.js"
  }
}
