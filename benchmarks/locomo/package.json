{
  "name": "@graphorin/benchmark-locomo",
  "version": "0.3.0",
  "private": true,
  "description": "LoCoMo memory-quality benchmark runner for the Graphorin framework. Replays multi-turn conversations against a memory-backed agent, scores the answers via deterministic exact-match + an LLM-as-judge scorer, and emits per-conversation accuracy + cost summaries. Ships a small bundled synthetic seed dataset; the public LoCoMo set can be downloaded on demand. Created and maintained by Oleksiy Stepurenko.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/benchmarks/locomo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "benchmarks/locomo"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "benchmark",
    "memory-evaluation"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx ./src/runner.ts",
    "build": "tsdown",
    "start": "node ./dist/runner.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "benchmark:run": "node ./dist/runner.js --dataset ./data/seed.jsonl",
    "benchmark:smoke": "node ./dist/runner.js --dataset ./data/seed.jsonl --smoke"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/agent": "workspace:*",
    "@graphorin/memory": "workspace:*",
    "@graphorin/sessions": "workspace:*",
    "@graphorin/store-sqlite": "workspace:*",
    "@graphorin/embedder-transformersjs": "workspace:*",
    "@graphorin/observability": "workspace:*",
    "@graphorin/pricing": "workspace:*",
    "@graphorin/provider": "workspace:*",
    "@graphorin/evals": "workspace:*"
  },
  "bin": {
    "graphorin-benchmark-locomo": "./dist/runner.js"
  }
}
