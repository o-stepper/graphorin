{
  "name": "@graphorin/benchmark-latency",
  "version": "0.9.0",
  "private": true,
  "description": "FTS memory-search latency probe for the Graphorin framework. Measures p50/p95/p99 latency for semantic-memory search over a synthetic FTS corpus (no embedder) and emits RESULTS.md. Streaming TTFT and fact-extraction latency are NOT measured here - they need a cached embedder and a live provider on a workstation profile. Created and maintained by Oleksiy Stepurenko.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/benchmarks/latency",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "benchmarks/latency"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "benchmark",
    "memory-evaluation"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx ./src/runner.ts",
    "build": "tsdown",
    "start": "node ./dist/runner.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "benchmark:run": "node ./dist/runner.js",
    "benchmark:smoke": "node ./dist/runner.js --smoke"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/memory": "workspace:*",
    "@graphorin/store-sqlite": "workspace:*"
  },
  "bin": {
    "graphorin-benchmark-latency": "./dist/runner.js"
  }
}
