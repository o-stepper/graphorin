{
  "name": "@graphorin/benchmark-memory-smoke",
  "version": "0.15.0",
  "private": true,
  "description": "Synthetic memory-retrieval smoke test for the Graphorin framework - a small set of hand-written QA cases scored by deterministic substring match, kept fast and offline for benchmark:ci. This is NOT the published LOCOMO benchmark; for the real memory-eval harness (LongMemEval + real LOCOMO + DMR with LLM-judge 'J' scoring and per-category regression gates) use @graphorin/benchmark-longmemeval. Created and maintained by Oleksiy Stepurenko.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/benchmarks/memory-smoke",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "benchmarks/memory-smoke"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "benchmark",
    "memory-evaluation"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx ./src/runner.ts",
    "build": "tsdown",
    "start": "node ./dist/runner.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "benchmark:run": "node ./dist/runner.js --dataset ./data/seed.jsonl",
    "benchmark:smoke": "node ./dist/runner.js --dataset ./data/seed.jsonl --smoke"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/agent": "workspace:*",
    "@graphorin/memory": "workspace:*",
    "@graphorin/sessions": "workspace:*",
    "@graphorin/store-sqlite": "workspace:*",
    "@graphorin/embedder-transformersjs": "workspace:*",
    "@graphorin/observability": "workspace:*",
    "@graphorin/pricing": "workspace:*",
    "@graphorin/provider": "workspace:*",
    "@graphorin/evals": "workspace:*"
  },
  "bin": {
    "graphorin-benchmark-memory-smoke": "./dist/runner.js"
  }
}
