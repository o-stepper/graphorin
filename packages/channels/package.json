{
  "name": "@graphorin/channels",
  "version": "0.13.3",
  "description": "Channel SPI for the Graphorin framework. Defines the vendor-neutral adapter contract for messenger front doors (inbound normalization, identity routing, pairing-based access policy, delivery), a gateway runtime that enforces the inbound trust boundary and outbound scaffolding sanitization, and a testkit with an in-memory loopback adapter plus a conformance suite. Ships no vendor adapters by design.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/packages/channels",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "packages/channels"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "channels",
    "messenger",
    "gateway",
    "adapter",
    "spi"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testkit": {
      "types": "./dist/testkit/index.d.ts",
      "default": "./dist/testkit/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json",
    "test": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/tools": "workspace:*"
  },
  "devDependencies": {
    "@graphorin/agent": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
