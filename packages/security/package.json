    "provenance": true
  },
  "devDependencies": {
    "@napi-rs/keyring": "^1.2.0",
    "@node-rs/argon2": "^2.0.2",
    "fast-check": "^3.23.0",
    "openid-client": "^6.8.0"
  }
}
