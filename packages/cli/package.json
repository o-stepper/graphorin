{
  "name": "@graphorin/cli",
  "version": "0.13.1",
  "description": "Operator CLI for the Graphorin framework. The `graphorin` binary covers the standalone server and the local stores end to end: `start`, `init`, `migrate`, `doctor`, `token`, `secrets`, `storage`, `audit`, `memory`, `consolidator`, `triggers`, `auth`, `pricing`, `skills`, `traces`, `guard`, `telemetry`, `tools`, and `migrate-export`. Created and maintained by Oleksiy Stepurenko.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "cli",
    "graphorin-start",
    "graphorin-init",
    "graphorin-migrate"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/bin/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "graphorin": "./dist/bin/graphorin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "default": "./dist/commands/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json",
    "test": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/eslint-plugin": "workspace:*",
    "@graphorin/memory": "workspace:*",
    "@graphorin/pricing": "workspace:*",
    "@graphorin/provider": "workspace:*",
    "@graphorin/security": "workspace:*",
    "@graphorin/server": "workspace:*",
    "@graphorin/sessions": "workspace:*",
    "@graphorin/skills": "workspace:*",
    "@graphorin/store-sqlite": "workspace:*",
    "@graphorin/workflow": "workspace:*",
    "commander": "^10.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@graphorin/store-sqlite-encrypted": "workspace:*"
  }
}
