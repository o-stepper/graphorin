{
  "name": "@graphorin/tools",
  "version": "0.12.1",
  "description": "Tools surface for the Graphorin framework: typed `tool({...})` builder backed by Zod schemas, ToolRegistry with strategy-aware collision resolution and deferred-loading support, ToolExecutor with parallel/sequential dispatch, approval flow, sandbox enforcement (via @graphorin/security), per-tool secrets ACL, memory-modification guard wiring, hard-kill cancellation with grace, single-round tool repair, inbound prompt-injection sanitization, four-strategy result truncation, streaming tool execution (progress + partial chunks with bounded backpressure), four-class side-effect taxonomy with idempotency-key callbacks, per-tool model-tier hints, and built-in `tool_search` for tool retrieval at scale.",
  "license": "MIT",
  "author": "Oleksiy Stepurenko",
  "homepage": "https://github.com/o-stepper/graphorin/tree/main/packages/tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-stepper/graphorin.git",
    "directory": "packages/tools"
  },
  "bugs": {
    "url": "https://github.com/o-stepper/graphorin/issues"
  },
  "keywords": [
    "graphorin",
    "ai",
    "agents",
    "framework",
    "tools",
    "tool-registry",
    "tool-executor",
    "zod",
    "approval-flow",
    "sandbox",
    "tool-repair",
    "inbound-sanitization",
    "deferred-loading",
    "tool-search",
    "side-effect-class",
    "idempotency",
    "streaming-tools"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./builder": {
      "types": "./dist/builder/index.d.ts",
      "default": "./dist/builder/index.js"
    },
    "./code-mode": {
      "types": "./dist/code-mode/index.d.ts",
      "default": "./dist/code-mode/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    },
    "./executor": {
      "types": "./dist/executor/index.d.ts",
      "default": "./dist/executor/index.js"
    },
    "./streaming": {
      "types": "./dist/streaming/index.d.ts",
      "default": "./dist/streaming/index.js"
    },
    "./inbound": {
      "types": "./dist/inbound/index.d.ts",
      "default": "./dist/inbound/index.js"
    },
    "./outbound": {
      "types": "./dist/outbound/index.d.ts",
      "default": "./dist/outbound/index.js"
    },
    "./result": {
      "types": "./dist/result/index.d.ts",
      "default": "./dist/result/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./built-in": {
      "types": "./dist/built-in/index.d.ts",
      "default": "./dist/built-in/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "default": "./dist/audit/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json",
    "test": "vitest run",
    "lint": "biome check .",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@graphorin/core": "workspace:*",
    "@graphorin/observability": "workspace:*",
    "@graphorin/security": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "fast-check": "^3.23.0",
    "zod": "^3.25.0"
  }
}
